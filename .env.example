# Environment variable for MCP server
GOOGLE_CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
USER_PROFILE_PATH="C:\\Users\\RanVic\\AppData\\Local\\Google\\Chrome\\User Data\\System Profile"

# Environment variables for Gemini MCP Client

# Required: Your Google Gemini API key (AIzaSyCXyJn6sBgcYQUw4HfTyTwhqYrjEugrV0k)
GEMINI_API_KEY=your-gemini-api-key-here
GEMMA_API_KEY=your-gemma-api-key-here

# Optional: Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Optional: MCP Chrome server URL (default: http://127.0.0.1:12306/mcp)
MCP_SERVER_URL=http://127.0.0.1:12306/mcp

# Optional: Enable debug logging (default: false)
DEBUG=false

#C:\\Users\\{UserName}\\cdp-use\\.venv\\Scripts\\python.exe -m cdp_use.mcp_server_fastmcp
MCP_SERVER_COMMAND=C:\\Path\\To\\Python\\python.exe -m cdp_use.mcp_server_fastmcp

# Optional: Enable visual context (default: false)
ENABLE_VISUAL_CONTEXT="false"
MAX_IMAGE_BYTES="1048576"

# Maximum number of steps the Agent can take to complete its goal (default: 20)
MAX_ITERATIONS=20