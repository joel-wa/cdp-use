flowchart TD
    subgraph "Gemini MCP Client Architecture"
        A1[GeminiMCPClient] --> B1[MCP Session]
        A1 --> C1[Gemini API Client]
        B1 --> D1[Load Tools from MCP]
        D1 --> E1[Convert to Gemini Format]
        C1 --> F1[Generate Content with Tools]
        F1 --> G1[Process Function Calls]
        G1 --> H1[Execute via MCP Session]
        H1 --> I1[Return Results]
    end
    
    subgraph "Gemini MCP Orchestrator Architecture"
        A2[GeminiMCPOrchestrator] --> B2[LLM Wrapper]
        B2 --> C2[OrchestratorLLM]
        A2 --> D2[Role Functions]
        B2 --> E2[Mock Tools Array]
        C2 --> F2[Generate Content]
        F2 --> G2[Process Function Calls]
        G2 --> H2[Mock Tool Execution]
        H2 --> I2[Return Mock Results]
    end
    
    subgraph "Key Differences"
        J1["✅ Real MCP Connection"] --> K1["Actual tool execution"]
        J2["❌ No MCP Connection"] --> K2["Mock tool execution"]
        J3["✅ Tool Loading"] --> K3["Real tool schemas"]
        J4["❌ Mock Tool Array"] --> K4["Placeholder schemas"]
    end
    
    style J1 fill:#90EE90
    style J3 fill:#90EE90
    style J2 fill:#FFB6C1
    style J4 fill:#FFB6C1