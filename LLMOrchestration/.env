# Environment variables for Gemini MCP Client

# Required: Your Google Gemini API key
GEMINI_API_KEY=AIzaSyDQQE7g0ae-5XHP0-1jNd8sueAH6xW7ok0
GEMMA_API_KEY = AIzaSyDQQE7g0ae-5XHP0-1jNd8sueAH6xW7ok0

# Optional: Gemini model to use (default: gemini-1.5-pro-latest)
